<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Hayley Clark | Painel</title>
    <style>
        body {
            background-color: #0d0d0d;
            color: #e6e6e6;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            margin: 0;
            overflow-x: hidden;
        }
        /* Fundo Animado */
        .bg-animated {
            position: fixed;
            width: 100vw;
            height: 100vh;
            background: radial-gradient(circle, #1a1a1a 10%, #050505 90%);
            z-index: -1;
            animation: pulseBg 12s infinite alternate;
        }
        @keyframes pulseBg {
            0% { filter: brightness(0.8); }
            100% { filter: brightness(1.2); }
        }
        /* Menu Principal */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            border-bottom: 1px solid #262626;
            background: rgba(13, 13, 13, 0.85);
            backdrop-filter: blur(8px);
        }
        .logo {
            font-size: 20px;
            font-weight: bold;
            letter-spacing: 1.5px;
            text-transform: uppercase;
        }
        nav a {
            color: #b3b3b3;
            text-decoration: none;
            margin: 0 15px;
            padding: 8px 16px;
            border: 1px solid transparent;
            transition: 0.3s;
        }
        nav a:hover, nav a.active {
            color: #fff;
            border: 1px solid #ffffff;
            background: #1a1a1a;
        }
        .container {
            max-width: 900px;
            margin: 60px auto;
            background: rgba(20, 20, 20, 0.9);
            border: 1px solid #333;
            border-radius: 4px;
            padding: 40px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.7);
        }
        h1, h2 {
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 2px;
            color: #ffffff;
        }
        .form-group {
            margin-bottom: 25px;
        }
        label {
            display: block;
            margin-bottom: 10px;
            font-weight: bold;
            color: #cccccc;
        }
        select, textarea, input[type="text"] {
            width: 100%;
            padding: 12px;
            background: #141414;
            border: 1px solid #333;
            color: #fff;
            border-radius: 4px;
            box-sizing: border-box;
            font-size: 15px;
        }
        select:focus, textarea:focus {
            outline: none;
            border-color: #fff;
        }
        button.btn-submit {
            display: block;
            width: 100%;
            padding: 15px;
            background: #ffffff;
            color: #000000;
            border: none;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            cursor: pointer;
            transition: 0.3s;
        }
        button.btn-submit:hover {
            background: #cccccc;
        }
    </style>
</head>
<body>
    <div class="bg-animated"></div>
    <header>
        <div class="logo">Hayley Clark</div>
        <nav>
            <a href="/" class="active">Início</a>
            <a href="/daily">Daily</a>
            <a href="/loja">Loja</a>
            <a href="/logout" style="color: #ff3333;">Sair</a>
        </nav>
        <div>
            <span><strong><%= user.username %></strong> (<%= balance %> Killcoins)</span>
        </div>
    </header>

    <div class="container">
        <h1>Configuração do Bot</h1>
        <p style="text-align: center; color: #888;">Configure os canais de boas-vindas diretamente do seu navegador de forma imediata.</p>

        <% if (guilds.length > 0) { %>
            <form action="/save-welcome" method="POST">
                <input type="hidden" name="guildId" value="<%= guilds[0].id %>">
                
                <div class="form-group">
                    <label>Servidor Gerenciado:</label>
                    <input type="text" value="<%= guilds[0].name %>" disabled>
                </div>

                <div class="form-group">
                    <label>Canal de Boas-Vindas:</label>
                    <select name="channelId">
                        <option value="">-- Selecione um Canal --</option>
                        <% channels.forEach(ch => { %>
                            <option value="<%= ch.id %>" <%= config.channelId === ch.id ? 'selected' : '' %>><%= ch.name %></option>
                        <% }) %>
                    </select>
                </div>

                <div class="form-group">
                    <label>Mensagem Customizada:</label>
                    <textarea name="message" rows="5" placeholder="Use {member}, {server} ou {total} como variáveis de texto..."><%= config.message || '' %></textarea>
                </div>

                <button type="submit" class="btn-submit">Salvar Alterações</button>
            </form>
        <% } else { %>
            <p style="text-align: center; color: #ff3333;">Você não possui permissão de Administrador em servidores que usam o bot.</p>
        <% } %>
    </div>
</body>
</html>