<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="UTF-8">
    <title>Hayley Clark | Daily</title>
    <style>
        body {
            background-color: #0d0d0d;
            color: #e6e6e6;
            font-family: 'Segoe UI', sans-serif;
            margin: 0;
        }
        .bg-animated {
            position: fixed;
            width: 100vw;
            height: 100vh;
            background: radial-gradient(circle, #1a1a1a 10%, #050505 90%);
            z-index: -1;
            animation: pulseBg 12s infinite alternate;
        }
        @keyframes pulseBg {
            0% { filter: brightness(0.8); }
            100% { filter: brightness(1.2); }
        }
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 40px;
            border-bottom: 1px solid #262626;
            background: rgba(13, 13, 13, 0.85);
            backdrop-filter: blur(8px);
        }
        .logo { font-size: 20px; font-weight: bold; text-transform: uppercase; }
        nav a { color: #b3b3b3; text-decoration: none; margin: 0 15px; padding: 8px 16px; border: 1px solid transparent; transition: 0.3s; }
        nav a:hover, nav a.active { color: #fff; border: 1px solid #fff; background: #1a1a1a; }
        
        .daily-box {
            max-width: 500px;
            margin: 100px auto;
            background: rgba(20, 20, 20, 0.95);
            border: 1px solid #333;
            border-radius: 4px;
            padding: 50px 30px;
            text-align: center;
            box-shadow: 0 10px 40px rgba(0,0,0,0.8);
        }
        .daily-box h1 {
            text-transform: uppercase;
            letter-spacing: 2px;
            font-size: 28px;
            margin-bottom: 20px;
        }
        .daily-box p {
            color: #888;
            font-size: 15px;
            margin-bottom: 35px;
        }
        .btn-claim {
            padding: 15px 40px;
            background: #ffffff;
            color: #000000;
            border: none;
            font-weight: bold;
            font-size: 16px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-claim:hover {
            background: #cccccc;
        }
        .success-banner {
            background: #222;
            border: 1px solid #fff;
            color: #fff;
            padding: 15px;
            margin-bottom: 25px;
            font-weight: bold;
        }
    </style>
</head>
<body>
    <div class="bg-animated"></div>
    <header>
        <div class="logo">Hayley Clark</div>
        <nav>
            <a href="/">Início</a>
            <a href="/daily" class="active">Daily</a>
            <a href="/loja">Loja</a>
            <a href="/logout" style="color: #ff3333;">Sair</a>
        </nav>
        <div>
            <span><strong><%= user.username %></strong> (<%= balance %> Killcoins)</span>
        </div>
    </header>

    <div class="daily-box">
        <h1>Recompensa Diária</h1>
        
        <% if (typeof success !== 'undefined' || (new URLSearchParams(global.location?.search)).get('success')) { %>
            <div class="success-banner">✓ Recompensa coletada com sucesso! +500 Killcoins</div>
        <% } %>

        <p>Acesse e pegue suas Killcoins diárias a cada 24 horas.</p>

        <form action="/daily/claim" method="POST">
            <button type="submit" class="btn-claim">Coletar Moedas</button>
        </form>
    </div>
</body>
</html>